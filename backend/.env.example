# ---------------------------------------------------------------------------
# Plimsoll backend environment template
# Copy this file to `.env` (same directory) and fill in the values you need.
#   cp .env.example .env
# All values are optional unless noted. Sensible defaults are used when unset.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# Local dev default: file-based SQLite. Docker Compose uses Postgres:
#   postgresql://plimsoll:plimsoll@postgres:5432/plimsoll
DATABASE_URL=sqlite:///./data/sully.db
# Prototype/dev only. Production should use Alembic migrations instead.
AUTO_CREATE_TABLES=true
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- 1.0 migration toggles --------------------------------------------------
# AUTH_BACKEND: clerk | supabase | dual
AUTH_BACKEND=clerk
# KB_BACKEND: chroma | pgvector | dual
KB_BACKEND=chroma
# UPLOAD_BACKEND: disk | supabase_storage
UPLOAD_BACKEND=disk
# QUEUE_BACKEND: none | pgmq | arq
QUEUE_BACKEND=none
REDIS_URL=redis://redis:6379/0

# --- HTTP / CORS ------------------------------------------------------------
# Comma-separated list of allowed browser origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Auth (Clerk) -----------------------------------------------------------
# Required for any endpoint that calls `get_current_user` (most /api/* routes).
# Leave blank only if you are running in a context where auth is mocked.
CLERK_ISSUER_URL=
# Comma-separated admin emails. These users get role=admin regardless of
# Clerk metadata. Never hardcode in source.
ADMIN_WHITELIST=

# --- Demo sessions ----------------------------------------------------------
# Used to sign short-lived demo WebSocket session tokens.
DEMO_SESSION_SECRET=replace-with-random-local-secret
DEMO_SESSION_TTL_SECONDS=3600

# --- LLM Providers ----------------------------------------------------------
# Choose one. CrewAI / agent endpoints fail gracefully when no key is set.
LLM_PROVIDER=ollama

# Google Gemini (preferred when set)
GOOGLE_API_KEY=

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Ollama (local, default provider when no cloud key is configured)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:latest

# --- Google Maps (optional) -------------------------------------------------
# Used by visual-risk / route imagery endpoints. Can share GOOGLE_API_KEY.
GOOGLE_MAPS_API_KEY=

# --- Supabase / Storage placeholders ---------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_SATELLITE_CACHE=satellite-cache
STORAGE_BUCKET_REPORTS=reports

# --- Vector store (Chroma) --------------------------------------------------
CHROMA_PERSIST_DIR=./data/vectordb
MARITIME_KB_PERSIST_DIR=./data/vectordb/maritime
# Only needed for hosted Chroma Cloud. Leave unset for local file store.
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

# --- Uploads / storage ------------------------------------------------------
UPLOAD_DIR=./data/uploads
DOCUMENTS_UPLOAD_DIR=./data/uploads/documents
MAX_UPLOAD_SIZE_MB=50
MARITIME_REGULATIONS_DIR=./data/maritime_regulations

# --- Feature flags ----------------------------------------------------------
DOCUMENT_ANALYSIS_USE_CREWAI=true

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
# Accepts: debug|on|dev|development  -> true
#          release|prod|off           -> false
DEBUG=false
