# ---------------------------------------------------------------------------
# Plimsoll backend environment template
# Copy to `.env` (same directory) and fill in the values you need.
#   cp .env.example .env
# All values are optional unless noted. Sensible defaults are used when unset.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# Local dev default: file-based SQLite. Docker Compose uses Postgres:
#   postgresql://plimsoll:plimsoll@postgres:5432/plimsoll
DATABASE_URL=sqlite:///./data/sully.db
# Prototype/dev only. Production should use Alembic migrations instead.
AUTO_CREATE_TABLES=true
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- 1.0 migration toggles --------------------------------------------------
# AUTH_BACKEND: supabase | dual
AUTH_BACKEND=supabase
# KB_BACKEND: pgvector | disabled
KB_BACKEND=pgvector
# UPLOAD_BACKEND: disk | supabase_storage
UPLOAD_BACKEND=disk
# QUEUE_BACKEND: none | pgmq | arq
QUEUE_BACKEND=none
REDIS_URL=redis://redis:6379/0
# Defaults to REDIS_URL when unset. Leave empty for in-process rate limits.
RATE_LIMIT_STORAGE_URL=
RATE_LIMIT_DEFAULT=120/minute

# --- HTTP / CORS ------------------------------------------------------------
# Comma-separated list of allowed browser origins. Wildcards forbidden when
# DEBUG=false.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Auth (Supabase) --------------------------------------------------------
# At least one of SUPABASE_URL (asymmetric JWKS) or SUPABASE_JWT_SECRET (legacy
# HS256) must be set in production. JWKS is fetched from
# {SUPABASE_URL}/auth/v1/.well-known/jwks.json unless SUPABASE_JWKS_URL overrides.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=
SUPABASE_JWT_SECRET=
# Comma-separated admin emails. These users get role=admin regardless of
# Supabase user_metadata. Never hardcode in source.
ADMIN_WHITELIST=

# --- Demo sessions ----------------------------------------------------------
# HMAC key for short-lived demo WebSocket session tokens. The dev default is
# rejected when DEBUG=false.
DEMO_SESSION_SECRET=dev-demo-session-secret
DEMO_SESSION_TTL_SECONDS=3600

# --- LLM providers ----------------------------------------------------------
# CrewAI / agent endpoints fail gracefully when no key is set.
LLM_PROVIDER=ollama

# Google Gemini (preferred when set)
GOOGLE_API_KEY=

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Groq (preferred when set; takes precedence over Google + OpenAI in the
# CrewAI factory). Free tier covers llama-3.3-70b-versatile + mixtral.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local, default provider when no cloud key is configured)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:latest

# --- Google Maps (optional) -------------------------------------------------
GOOGLE_MAPS_API_KEY=

# --- Storage placeholders ---------------------------------------------------
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_SATELLITE_CACHE=satellite-cache
STORAGE_BUCKET_REPORTS=reports

# --- Vector store (Postgres pgvector) --------------------------------------
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=768

# --- Uploads / storage ------------------------------------------------------
UPLOAD_DIR=./data/uploads
DOCUMENTS_UPLOAD_DIR=./data/uploads/documents
MAX_UPLOAD_SIZE_MB=50
MARITIME_REGULATIONS_DIR=./data/maritime_regulations

# --- LLM cost ledger --------------------------------------------------------
# Optional JSON map: {"model_name": [in_per_M, out_per_M]} in USD.
LLM_PRICING_OVERRIDES_JSON=

# --- Feature flags ----------------------------------------------------------
DOCUMENT_ANALYSIS_USE_CREWAI=false

# --- Logging ----------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
# Accepts: debug|on|dev|development  -> true
#          release|prod|production|off -> false
DEBUG=false
